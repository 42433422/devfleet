{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PaibiPara",
  "version": "1.4.7",
  "identifier": "com.devfleet.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm run client:dev",
    "beforeBuildCommand": "npm run build && npm run server:build && npm run mcp:build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "create": false,
        "title": "排比 Para - 多设备协同控制",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:* http://192.168.0.0/16 http://10.0.0.0/8 http://172.16.0.0/12 https: wss:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.13"
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "resources": {
      "../dist-server/devfleet-server.cjs": "server/devfleet-server.cjs",
      "../dist-server/node_modules": "server/node_modules",
      "../dist-server/runtime": "server/runtime",
      "../dist-mcp/devfleet-mcp.mjs": "mcp/devfleet-mcp.mjs",
      "../scripts/computer-use/trae-new-task.ps1": "scripts/trae-new-task.ps1"
    }
  }
}
