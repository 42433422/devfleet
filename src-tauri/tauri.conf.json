{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevFleet",
  "version": "1.3.7",
  "identifier": "com.devfleet.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && npm run server:build && npm run mcp:build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "create": false,
        "title": "DevFleet - 多设备协同控制",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:3001 http://127.0.0.1:3001 ws://localhost:3001 ws://127.0.0.1:3001 https:; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.13"
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "resources": {
      "../dist-server/devfleet-server.cjs": "server/devfleet-server.cjs",
      "../dist-mcp/devfleet-mcp.mjs": "mcp/devfleet-mcp.mjs",
      "../scripts/computer-use/trae-new-task.ps1": "scripts/trae-new-task.ps1"
    }
  }
}
