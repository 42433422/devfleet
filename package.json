{
  "name": "devfleet",
  "private": true,
  "version": "1.3.16",
  "type": "module",
  "scripts": {
    "client:dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "server:dev": "nodemon",
    "server": "tsx api/server.ts",
    "server:build": "node scripts/prepare-server-bundle.mjs",
    "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\"",
    "test": "npm run mcp:build && tsx --test tests/*.test.ts",
    "test:scope": "npm run mcp:build && node scripts/test-scope.mjs",
    "mcp": "tsx mcp/server.ts",
    "mcp:build": "esbuild mcp/server.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist-mcp/devfleet-mcp.mjs && node scripts/copy-mcp-assets.mjs",
    "e2e:setup": "bash scripts/e2e-setup-git-repo.sh",
    "e2e:agent": "node scripts/e2e-agent.mjs",
    "e2e:loop": "tsx scripts/e2e-minimal-loop.ts",
    "demo:fresh": "npm run server:build && bash scripts/demo-fresh-start.sh",
    "demo:run": "bash scripts/demo-run.sh",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tauri-apps/api": "^2.11.0",
    "ajv": "^8.20.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.11.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "localtunnel": "^2.0.2",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.3.0",
    "tailwind-merge": "^3.0.2",
    "tsx": "^4.20.3",
    "ws": "^8.18.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@tauri-apps/cli": "^2.5.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-dev-locator": "^1.0.0",
    "concurrently": "^9.2.0",
    "esbuild": "^0.25.12",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
